;; Make ESC quit prompts
(global-set-key (kbd "<escape>") 'keyboard-escape-quit)

;; ---------------------------------------------------------------------------
;; IDE CONFIGURATION
;; ---------------------------------------------------------------------------

;; Core
(use-package which-key
    :config
    (which-key-mode))

(use-package company
    :hook (after-init . global-company-mode)
    :custom
    (company-minimum-prefix-length 1))

(use-package lsp-mode
    :commands lsp
    :hook ((python-mode . lsp)
           (c-mode      . lsp)
           (c++-mode    . lsp)
           (sh-mode     . lsp))
    :custom

    (lsp-enable-symbol-highlighting t))

(use-package lsp-ui
    :commands lsp-ui-mode)

(use-package lsp-ivy
    :commands lsp-ivy-workspace-symbol)

;; UI
(use-package doom-modeline
    :init
    (doom-modeline-mode 1)
    :custom
    (doom-modeline-height 15))

(use-package nerd-icons
    :if (display-graphic-p)) ;; font install may be required (run all-the-icons-install-fonts)

;; ---------------------------------------------------------------------------
;; Languages
;; ---------------------------------------------------------------------------

;; ------------------------
;; Python
;; ------------------------
;; python-mode (built-in): enable lsp and set indent
(use-package python
    :ensure nil
    :hook (python-mode . (lambda ()
        (setq python-indent-offset 4)
        (lsp))))

;; virtualenv/venv support
(use-package pyvenv
    :hook (python-mode . pyvenv-mode))

;; pipenv integration
(use-package pipenv
    :hook (python-mode . pipenv-mode))

;; format on save using black
(use-package python-black
    :after python
    :hook (python-mode . python-black-on-save-mode)
    :custom
    (python-black-extra-args '("--fast")))

;; ------------------------
;; Shell / Bash (sh-mode)
;; ------------------------
;; built-in sh-mode: enable LSP (if bash-language-server installed) and set basic offset
(use-package sh-script
    :ensure nil
    :hook (sh-mode . (lambda ()
        (setq sh-basic-offset 2)
        (lsp)))) ;; requires bash-language-server for LSP features


;; Optional: format on save with shfmt (if installed)
(defun my/shfmt-buffer ()
    (when (and (eq major-mode 'sh-mode) (executable-find "shfmt"))
        (call-process-region (point-min) (point-max) "shfmt" t t nil "-w")))
(add-hook 'before-save-hook #'my/shfmt-buffer)

;; ------------------------
;; PowerShell
;; ------------------------

;; ------------------------
;; C / C++
;; ------------------------
;; cc-mode (built-in): enable lsp and set style
(use-package cc-mode
    :ensure nil
    :hook ((c-mode c++-mode) . (lambda ()
        (setq c-default-style "linux"
              c-basic-offset 4)
        (lsp))))

;; clang-format for formatting C/C++ (format on save for buffers in c-mode)
(use-package clang-format
    :commands (clang-format-buffer)
    :config
    (add-hook 'c-mode-hook
        (lambda ()
            (add-hook 'before-save-hook #'clang-format-buffer nil t))))


;; ---------------------------------------------------------------------------
;; PROJECT MANAGEMENT
;; ---------------------------------------------------------------------------
(use-package project
    :ensure nil
    :config
    (setq project-switch-commands '("consult-projectile")))

(use-package projectile
    :init
    (projectile-mode +1)
    :bind-keymap
    ("C-c p" . projectile-command-map)
    :custom
    (projectile-completion-system 'consult))

(use-package vterm
    :commands vterm
    :config
    (setq vterm-max-scrollback 10000))

;; Compilation and quick-run
(global-set-key (kbd "C-c c") 'compile) ;; run make/compile
(global-set-key (kbd "C-c r")
                (lambda ()
                    (interactive)
                    (call-interactively 'compile))) ;; run arbitrary compile command

;; DAP (debug adapter protocol) for debugging (optional)
(use-package dap-mode
    :after lsp-mode
    :config
    (dap-mode 1)
    (dap-ui-mode 1))

(use-package magit
    :commands magit-status)

(use-package yasnippet
    :init
    (yas-global-mode 1))

;; ------------------------
;; Ivy / Counsel / Swiper
;; ------------------------
(use-package ivy
    :diminish
    :bind (("C-s" . swiper)                    ;; swiper for in-buffer search
           :map ivy-minibuffer-map
           ("TAB" . ivy-alt-done)
           ("C-j" . ivy-next-line)
           ("C-k" . ivy-previous-line))
    :config
    (ivy-mode 1)
    (setq ivy-use-virtual-buffers t
          ivy-count-format "(%d/%d) "
          ivy-format-function #'ivy-format-function-line))

(use-package counsel
    :after ivy
    :config
    (counsel-mode 1))

(use-package swiper
    :after ivy
    :bind (("C-s" . swiper)))


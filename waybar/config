{
  "layer": "top",
  "position": "top",
  "height": 24,

  "modules-left": ["sway/workspaces"],
  "modules-center": ["clock"],
  "modules-right": ["cpu", "memory", "tray"],

  "clock": {
    "format": "{:%H:%M}"
  },

  "cpu": {
    "format": "CPU {usage}%"
  },

  "memory": {
    "format": "RAM {used:0.1f}G"
  },

  "tray": {
    "spacing": 8
  }
}
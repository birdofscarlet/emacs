* {
  font-family: "Noto Sans";
  font-size: 11px;
  border: none;
}

window#waybar {
  background: #000000;
  color: #ffffff;
}

/* workspaces (like buffer list) */
#workspaces button {
  padding: 0 6px;
  color: #888888;
}

#workspaces button.focused {
  color: #00d3d0;
}

/* current window (like buffer name) */
#window {
  color: #ffffff;
}

/* right side (like minor info) */
#clock {
  padding: 0 6px;
  color: #aaaaaa;
}
